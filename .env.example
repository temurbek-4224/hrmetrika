# ─────────────────────────────────────────────────────────────────
# HR Metrika — Frontend Environment Variables
# Copy this file to .env.local for local development.
# On Vercel, set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# Full origin of the Render backend (no trailing slash).
# Leave UNSET in local development — Vite's proxy handles /api/* instead.
# Required in production (Vercel).
VITE_API_URL=https://hrmetrika.onrender.com
